# ===========================
# API Keys (MANDATORY)
# ===========================
GROQ_API_KEY=""
HF_API_KEY=""
ANTHROPIC_API_KEY=""

# ===========================
# Backend App Config
# ===========================
APP_ENV=development
APP_PORT=8000
DEBUG=True

# ===========================
# Vector Database (Choose One)
# ===========================
# For Local/Docker deployment:
VECTOR_STORE_TYPE=chroma 
CHROMA_SERVER_MODE=http  # 'http' for separate container, 'persistent' for single-service
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_DIR=./vectordb/chroma_data


# For Cloud deployment (Free Forever path):
# VECTOR_STORE_TYPE=pinecone
# PINECONE_API_KEY=your-api-key
# PINECONE_INDEX_NAME=shamba-ai

# ===========================
# PostgreSQL Database
# ===========================
# For Cloud deployment (Neon.tech):
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_SSL=require

# ===========================
# Frontend Config
# ===========================
# REACT_APP_API_URL=https://your-backend.onrender.com
