# ===========================
# LLM & Embedding Keys
# ===========================
GROQ_API_KEY=your-groq-key-here
HF_API_KEY=your-huggingface-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here   # optional fallback

# ===========================
# App Config
# ===========================
APP_ENV=development
APP_PORT=8000
DEBUG=True

# ===========================
# ChromaDB
# ===========================
CHROMA_SERVER_HOST=chromadb
CHROMA_HOST=chromadb
CHROMA_SERVER_PORT=8000
CHROMA_PORT=8000
CHROMA_COLLECTION=shamba_rag

# ===========================
# PostgreSQL
# ===========================
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=postgres_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=shambadb
DATABASE_URL=postgresql+asyncpg://postgres_user:postgres_password@postgres:5432/shambadb

# ===========================
# Language
# ===========================
DEFAULT_LANGUAGE=sw
